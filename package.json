{
  "name": "music-markdown-syntax",
  "displayName": "Music Markdown Syntax",
  "description": "Syntax highlighting and lightweight chord validation for Music Markdown (music-markdown) chord/lyric files, injected into Markdown.",
  "version": "0.1.0",
  "publisher": "curtisgibby",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/curtisgibby/music-markdown-syntax.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "music markdown",
    "music-markdown",
    "chords",
    "guitar",
    "lyrics",
    "markdown"
  ],
  "contributes": {
    "grammars": [
      {
        "scopeName": "music-markdown.injection",
        "path": "./syntaxes/music-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ]
      }
    ]
  }
}
